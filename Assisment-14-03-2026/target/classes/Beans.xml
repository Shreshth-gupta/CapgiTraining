<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
    <context:annotation-config/>
    <bean id="Book" class="com.cg.beans.Book">
        <constructor-arg name="bookId" value="101"/>
        <constructor-arg name="title" value="COC"/>
        <constructor-arg name="author" value="Shreshtha"/>
    </bean>
    <bean id="Librarian" class="com.cg.beans.Librarian">
        <property name="librarianId" value="1"/>
        <property name="name" value="Jack"/>
        <property name="book" ref="Book"/>
    </bean>
</beans>

